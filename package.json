{
  "name": "itqhub-website-challenge",
  "version": "1.0.0",
  "private": true,
  "description": "ITQHUB Website Challenge — Production-grade MERN monorepo",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "npm run build --workspace=client",
    "start": "npm run start --workspace=server"
  },
  "keywords": ["itqhub", "mern", "monorepo"],
  "author": "Karan",
  "license": "MIT"
}
